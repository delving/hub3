{
  "baseUrl": "https://acpt.dcn.hubs.delving.org/api/search/v2",
  "fallback": "imageSearch",
  "urls": {
    "imageSearchPage": {
      "path": [
        "nk-collectie"
      ]
    },
    "imagePage": {
      "path": [
        "nk-collectie",
        ":hubID"
      ]
    }
  },
  "components": [
    {
      "key": "imageSearch",
      "navigation": false,
      "type": "grid",
      "facets": {},
      "linkTo": "imagePage",
      "display": [
        {
          "type": "image",
          "value": "thumbnail"
        },
        {
          "value": "objectID"
        },
        {
          "value": "title"
        }
      ],
      "requestUrls": {
        "search": {
          "path": [
            ":baseUrl"
          ],
          "query": [
            {
              "key": "facet.field",
              "value": "nave_objectCategory"
            },
            {
              "key": "qf",
              "value": "meta.spec:nk"
            }
          ]
        }
      },
      "routes": [
        "imageSearchPage"
      ]
    },
    {
      "key": "image",
      "pagination": false,
      "navigation": false,
      "type": "image",
      "facets": {},
      "linkTo": "imagePage",
      "requestUrls": {
        "search": {
          "path": [
            ":baseUrl",
            ":hubID"
          ],
          "query": [
            {
              "key": "itemFormat",
              "value": "grouped"
            }
          ]
        }
      },
      "display": {
        "ownershipHistory": {
          "label": "Herkomstgeschiedenis",
          "items": [
            {
              "label": "Restitutie status",
              "path": [
                "nk_restitutionState"
              ]
            },
            {
              "label": "Herkomst conclusie",
              "path": [
                "nk_herkomstConclusion"
              ]
            },
            {
              "label": "Na oorlogs bezit",
              "values": [
                "In het bezit gekomen van de Nederlandse overheid"
              ]
            }
          ]
        },
        "source": {
          "label": "rdf_label",
          "asLink": "nk_providerURL",
          "items": [
            {
              "label": "Bron",
              "path": ["nk_dataSource"]
            },
            {
              "path": ["dcterms_hasParts", "dc_identifier"],
              "linkTo": "imagePage",
              "style": {
                "horizontal": true
              }
            }
          ]
        },
        "sections": [
          {
            "image": {
              "src": "nk_thumbnail",
              "alt": "No image"
            },
            "label": "Identificatie",
            "items": [
              {
                "label": "Titel",
                "path": [
                  "dc_title"
                ]
              },
              {
                "label": "NK nummer",
                "path": [
                  "nk_objectNumber"
                ]
              },
              {
                "label": "Beschrijving",
                "path": [
                  "dc_description"
                ]
              }
            ]
          },
          {
            "label": "Vervaardiging",
            "items": [
              {
                "label": "Vervaardiger",
                "path": [
                  "creator",
                  "nk_creatorName"
                ]
              },
              {
                "label": "Datum start",
                "path": [
                  "nk_productionDate",
                  "nk_dateStart"
                ]
              },
              {
                "label": "Datum einde",
                "path": [
                  "nk_productionDate",
                  "nk_dateEnd"
                ]
              }
            ]
          },
          {
            "label": "Fysieke kenmerken",
            "items": [
              {
                "label": "Materiaal",
                "path": [
                  "nave_material"
                ]
              },
              {
                "label": "Hoogte/lengte",
                "path": [
                  "dimension",
                  "nk_heightLenght"
                ]
              },
              {
                "label": "Diameter",
                "path": [
                  "dimension",
                  "nk_depthDiameter"
                ]
              }
            ]
          },
          {
            "label": "Onderwerp",
            "items": [
              {
                "label": "Wat",
                "path": [
                  "dc_subject"
                ]
              },
              {
                "label": "Object categorie",
                "path": [
                  "nave_objectCategory"
                ]
              },
              {
                "label": "Object naam",
                "path": [
                  "nave_objectName"
                ]
              }
            ]
          }
        ]
      },
      "routes": [
        "imagePage"
      ]
    }
  ]
}